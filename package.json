{
  "name": "moonrepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/*"
  ],
  "scripts": {
    "prepare": "if [ -z \"$CI\" ]; then lefthook install; fi",
    "dev": "moon run :dev",
    "build": "moon run :build",
    "lint": "moon run :lint",
    "type-check": "moon run :type-check"
  },
  "engines": {
    "node": "22.21.1",
    "bun": "1.3.3"
  },
  "dependencies": {
    "@devcontainers/cli": "0.82.0",
    "@tree-sitter-grammars/tree-sitter-toml": "^0.7.0",
    "prisma": "7.3.0",
    "tree-sitter-bash": "^0.25.1",
    "tree-sitter-typescript": "^0.23.2",
    "tree-sitter-yaml": "^0.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "dorita980": "3.1.11",
    "lefthook": "^1.11.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cli": "^0.26.8"
  },
  "overrides": {
    "hono": ">=4.12.4",
    "@hono/node-server": ">=1.19.10",
    "tar": ">=7.5.10",
    "picomatch": "4.0.4",
    "minimatch": "10.2.3",
    "defu": "6.1.5",
    "lodash": "4.18.0",
    "path-to-regexp": "0.1.13",
    "effect": "3.20.0"
  }
}
