# ESPHome secrets — copy to secrets.yaml in the /config PVC and fill in real values.
# secrets.yaml is NEVER committed to Git (see .gitignore).
# This example file documents all required keys.

# Wi-Fi credentials
wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# ESPHome API encryption key (generate with: openssl rand -base64 32)
api_encryption_key: "CHANGE_ME"

# OTA update password
ota_password: "CHANGE_ME"

# MQTT broker (LAN IP or hostname) and port
mqtt_broker: "192.168.1.x"
mqtt_port: "31883"

# iBeacon UUIDs for BLE triangulation (from HA companion app settings)
phone1_ibeacon_uuid: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
watch1_ibeacon_uuid: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
phone2_ibeacon_uuid: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# watch2_ibeacon_uuid: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # uncomment when ready
