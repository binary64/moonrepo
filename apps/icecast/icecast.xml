<icecast>
    <location>Bournemouth, UK</location>
    <admin>admin@arthurradio.local</admin>

    <limits>
        <clients>10</clients>
        <sources>2</sources>
        <!-- Tuned for Google Nest / Chromecast listeners @ 192 kbps (≈24576 B/s).
             burst-size 245760 ≈ 10s: matches the Cast receiver's deep pre-buffer so
             playback starts near-instantly on "radio on" (no slow self-fill).
             queue-size 983040 ≈ 40s (4× burst): generous jitter tolerance over WiFi,
             prevents "fallen too far behind" disconnects the watchdog would re-cast.
             burst-on-connect removed — deprecated no-op in modern Icecast. -->
        <queue-size>983040</queue-size>
        <client-timeout>60</client-timeout>
        <header-timeout>30</header-timeout>
        <source-timeout>15</source-timeout>
        <burst-size>245760</burst-size>
    </limits>

    <authentication>
        <source-password>${ICECAST_SOURCE_PASSWORD}</source-password>
        <relay-password>${ICECAST_RELAY_PASSWORD}</relay-password>
        <admin-user>admin</admin-user>
        <admin-password>${ICECAST_ADMIN_PASSWORD}</admin-password>
    </authentication>

    <hostname>localhost</hostname>

    <listen-socket>
        <port>8100</port>
    </listen-socket>

    <mount>
        <mount-name>/stream</mount-name>
        <fallback-mount>/silence</fallback-mount>
        <fallback-override>1</fallback-override>
    </mount>

    <mount>
        <mount-name>/stream-video</mount-name>
        <type>video/mp2t</type>
        <fallback-mount>/silence</fallback-mount>
        <fallback-override>1</fallback-override>
    </mount>

    <fileserve>1</fileserve>

    <paths>
        <basedir>/usr/share/icecast2</basedir>
        <logdir>/var/log/icecast2</logdir>
        <webroot>/usr/share/icecast2/web</webroot>
        <adminroot>/usr/share/icecast2/admin</adminroot>
    </paths>

    <logging>
        <accesslog>-</accesslog>
        <errorlog>-</errorlog>
        <loglevel>3</loglevel>
    </logging>
</icecast>
