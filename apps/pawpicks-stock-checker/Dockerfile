FROM node:22-alpine

WORKDIR /app

# Install dependencies using lockfile for deterministic builds (skips devDependencies)
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# Copy TypeScript source
COPY tsconfig.json ./
COPY src/ ./src/

# Copy products data (generated by moon copy-data task from pawpicks-uk)
COPY products.json ./

# Run as non-root (uid 1000 matches securityContext.runAsUser in k8s)
# /data is mounted as a PVC with fsGroup: 1000 — no chown needed
RUN addgroup -S checker && adduser -S checker -G checker && chown -R checker:checker /app
USER checker

CMD ["node", "--import", "tsx/esm", "src/index.ts"]
