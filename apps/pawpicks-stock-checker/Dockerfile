FROM node:22-alpine

WORKDIR /app

# Install dependencies using lockfile for deterministic builds (skips devDependencies)
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# Copy TypeScript source
COPY tsconfig.json ./
COPY src/ ./src/

# Copy products data (generated by moon copy-data task from pawpicks-uk)
COPY products.json ./

# Output directory (mounted as PVC in k8s)
RUN mkdir -p /data

# Run as non-root
RUN addgroup -S checker && adduser -S checker -G checker && chown -R checker:checker /app /data
USER checker

CMD ["node", "--import", "tsx/esm", "src/index.ts"]
