# Required: HMAC-SHA256 secret (set this in GitHub repo webhook settings)
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# OpenClaw Gateway URL (default: http://localhost:6798)
OPENCLAW_GATEWAY_URL=http://localhost:6798

# OpenClaw session to deliver notifications to
OPENCLAW_SESSION_KEY=agent:main:telegram:direct:james

# Server port (default: 3200)
PORT=3200
