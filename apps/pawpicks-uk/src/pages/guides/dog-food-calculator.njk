<script>
(function () {
  var $ = function (id) { return document.getElementById(id); };
  var fallback = $('dfFallback');
  if (fallback) { fallback.style.display = 'none'; }

  var foodSel = $('dfFood');
  var foodCustom = $('dfFoodCustom');

  function fmt(n) { return Math.round(n).toLocaleString('en-GB'); }

  function foodDensity() {
    if (foodSel.value === 'custom') {
      var v = parseFloat(foodCustom.value);
      return (isFinite(v) && v > 0) ? v : NaN;
    }
    return parseFloat(foodSel.value);
  }

  function render() {
    var weight = parseFloat($('dfWeight').value);
    var unit = $('dfUnit').value;
    var factor = parseFloat($('dfFactor').value);
    var meals = parseInt($('dfMeals').value, 10);
    var kcal100 = foodDensity();
    var out = $('dfResult');

    if (!isFinite(weight) || weight <= 0) {
      out.innerHTML = '<p style="margin:0;color:var(--color-text-light);">Enter a weight to see the result.</p>';
      return;
    }
    var kg = unit === 'lb' ? weight * 0.453592 : weight;
    if (kg < 0.4 || kg > 120) {
      out.innerHTML = '<p style="margin:0;color:var(--color-text-light);">That weight looks out of range — double-check the number and unit.</p>';
      return;
    }

    var rer = 70 * Math.pow(kg, 0.75);
    var mer = rer * factor;
    var treat = mer * 0.10;

    var gramsLine = '';
    if (isFinite(kcal100) && kcal100 > 0) {
      var grams = mer / kcal100 * 100;
      var perMeal = grams / meals;
      gramsLine =
        '<div style="font-size:1.6rem;font-weight:700;color:var(--color-primary,#2a7);margin:0.25rem 0;">' +
          '≈ ' + fmt(grams) + ' g of food per day' +
        '</div>' +
        '<p style="margin:0.25rem 0 0;">That\'s about <strong>' + fmt(perMeal) + ' g per meal</strong> across ' + meals + ' meal' + (meals > 1 ? 's' : '') + '.</p>';
    } else {
      gramsLine = '<p style="margin:0.25rem 0;color:#b00;">Enter the kcal/100g from your food\'s label to get grams per day.</p>';
    }

    out.innerHTML =
      '<p style="margin:0 0 0.35rem;font-weight:600;">Estimated daily need</p>' +
      '<div style="font-size:1.25rem;font-weight:700;margin:0 0 0.5rem;">' + fmt(mer) + ' kcal/day</div>' +
      gramsLine +
      '<p style="margin:0.75rem 0 0;font-size:0.9em;color:var(--color-text-light);">' +
        'Resting need (RER) ' + fmt(rer) + ' kcal · activity factor ×' + factor + ' · ' +
        'treat allowance ≈ <strong>' + fmt(treat) + ' kcal</strong> (keep treats under 10% and subtract from meals).' +
      '</p>' +
      '<p style="margin:0.5rem 0 0;font-size:0.85em;color:var(--color-text-light);">' +
        'A starting point — feed for 2–3 weeks, then adjust ±10% by body condition. Not veterinary advice.' +
      '</p>';
  }

  foodSel.addEventListener('change', function () {
    foodCustom.style.display = (foodSel.value === 'custom') ? 'block' : 'none';
    if (foodSel.value === 'custom') { foodCustom.focus(); }
    render();
  });

  // Breed quick-start: prefill the typical adult midpoint weight from the breed's range.
  var breedSel = $('dfBreed');
  function midpointKg(range) {
    if (!range) { return NaN; }
    var nums = String(range).match(/[0-9]+(?:\.[0-9]+)?/g);
    if (!nums || !nums.length) { return NaN; }
    if (nums.length === 1) { return parseFloat(nums[0]); }
    var lo = parseFloat(nums[0]);
    var hi = parseFloat(nums[1]);
    return (lo + hi) / 2;
  }
  if (breedSel) {
    breedSel.addEventListener('change', function () {
      var opt = breedSel.options[breedSel.selectedIndex];
      if (!opt || !opt.value) { return; }
      var mid = midpointKg(opt.getAttribute('data-mid'));
      if (isFinite(mid) && mid > 0) {
        $('dfUnit').value = 'kg';
        // Round to a sensible step: 0.1 for toy dogs, whole kg otherwise.
        $('dfWeight').value = mid < 5 ? Math.round(mid * 10) / 10 : Math.round(mid);
        // A breed preset is an adult-dog assumption; default the factor to typical neutered adult.
        $('dfFactor').value = '1.6';
        render();
      }
    });
    // Optional deep-link: /dog-food-calculator/?breed=labradors prefills on load.
    try {
      var qs = new URLSearchParams(window.location.search);
      var pre = qs.get('breed');
      if (pre) {
        for (var i = 0; i < breedSel.options.length; i++) {
          if (breedSel.options[i].value === pre) {
            breedSel.selectedIndex = i;
            breedSel.dispatchEvent(new Event('change'));
            break;
          }
        }
      }
    } catch (e) { /* URLSearchParams unsupported — ignore */ }
  }

  ['dfWeight', 'dfUnit', 'dfFactor', 'dfMeals', 'dfFoodCustom'].forEach(function (id) {
    var el = $(id);
    el.addEventListener('input', render);
    el.addEventListener('change', render);
  });

  render();
})();
</script>
