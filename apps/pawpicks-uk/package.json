{
  "name": "pawpicks-uk",
  "version": "1.0.0",
  "description": "UK pet product reviews - honest, data-driven recommendations",
  "scripts": {
    "build": "eleventy",
    "serve": "eleventy --serve",
    "clean": "rm -rf _site",
    "audit": "python3 scripts/site-audit.py",
    "audit:launch": "python3 scripts/site-audit.py --strict-cta",
    "build:ci": "eleventy && python3 scripts/site-audit.py"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-rss": "^2.0.2",
    "markdown-it": "^14.0.0"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "liquidjs": "10.26.0",
    "linkify-it": ">=5.0.1",
    "ws": ">=8.21.0"
  }
}
